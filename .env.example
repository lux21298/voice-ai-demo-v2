# OpenAI Configuration
# Optional for local UI/demo mode. Required for real transcription, AI responses, and TTS.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.7

# MCP Server Configuration
MCP_SERVER_URL=http://localhost:3000/api/mcp

# Upstash Redis Configuration
# Optional. If omitted, the app uses in-memory cache/session storage.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Twilio Configuration
# Optional. Required only for outbound phone-call features.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WEBHOOK_URL=

# Application Configuration
NEXT_PUBLIC_BASE_URL=http://localhost:3000
SESSION_TTL=1800
MAX_HISTORY_LENGTH=10

# Analytics
ENABLE_ANALYTICS=true
